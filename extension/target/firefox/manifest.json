{
  "manifest_version": 2,
  "name": "LocalFlow",
  "short_name": "LocalFlow",
  "version": "2.6.0",
  "description": "A private new-tab workspace for todos, notes, plans, and personal sync.",
  "applications": {
    "gecko": {
      "id": "extension@localflow.local",
      "strict_min_version": "54.0"
    }
  },
  "chrome_settings_overrides": {
    "homepage": "index.html"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage", "https://*.ts.net/*"]
}
