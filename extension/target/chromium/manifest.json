{
  "manifest_version": 3,
  "name": "LocalFlow",
  "short_name": "LocalFlow",
  "version": "2.6.0",
  "description": "A private new-tab workspace for todos, notes, plans, and personal sync.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://*.ts.net/*"]
}
